{
  "mcpServers": {
    "neo4j": {
      "command": "./toolbox.exe",
      "args": ["--config", "tools.yaml", "--stdio"],
      "env": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}",
        "NEO4J_DATABASE": "neo4j"
      }
    }
  }
}
