# Copy to .env and adjust. .env is gitignored.

# --- Neo4j (matches docker-compose) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-local-dev

# --- Wiki source ---
# Point this at any folder of interlinked .md notes. Defaults to the bundled
# demo so the project runs clone-and-run. Set it to your own vault to use yours.
WIKI_DIR=./sample-wiki

# --- Synthesis (answer.py) ---
# Uses the Gemini API by default. Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
